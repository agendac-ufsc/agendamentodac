# ============================================================
# Sistema de Agendamento DAC/UFSC — Variáveis de Ambiente
# ============================================================
# No Replit: configure cada uma como Secret (não use arquivo .env)
# No Vercel: configure em Settings → Environment Variables
# ============================================================

# --- Upstash Redis (banco de dados principal) ---
# Obter em: https://console.upstash.com → seu DB → REST API
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Google Calendar API (Service Account) ---
# JSON COMPLETO da service account em UMA linha (cole o conteúdo do .json)
# A planilha do Google Sheets e os calendários precisam ser COMPARTILHADOS
# com o e-mail "client_email" desta service account.
# E-mail atual: agendamento-dac-service@agendamento-dac.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com",...}

# --- Brevo (envio de e-mails) ---
# Obter em: https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- E-mails ---
SENDER_EMAIL=remetente@dominio.com
ADMIN_EMAIL=admin@dominio.com

# --- Admin (opcional) ---
# Senha do painel admin. Padrão se não definido: admin.dac.ufsc
# ADMIN_PASSWORD=sua_senha_admin

# --- Servidor (opcional) ---
# Porta. Padrão: 5000 no Replit, definida pela plataforma no Vercel
# PORT=5000

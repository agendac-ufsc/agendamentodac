{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "react-router",
  "functions": {
    "dist/index.js": {
      "runtime": "nodejs@20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/dist/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}

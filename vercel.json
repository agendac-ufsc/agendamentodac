{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin",
      "dest": "admin.html"
    },
    {
      "src": "/avaliador",
      "dest": "avaliador.html"
    },
    {
      "src": "/termo",
      "dest": "termo.html"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
